<Window x:Class="HdrTracer.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정보"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="TitleText"
                       Text="정보"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
            <Button Grid.Column="1"
                    Click="CloseButton_Click"
                    Style="{StaticResource CloseButtonStyle}"
                    Content="&#xE8BB;"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- 본문 -->
        <Grid Grid.Row="1" Margin="24,20,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 앱 이름 + 아이콘 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <Image Source="/Assets/sun.ico" Width="32" Height="32" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="HdrTracer"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="VersionText"
                               Text="버전 1.0"
                               Foreground="#888"
                               FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- 설명 -->
            <TextBlock Grid.Row="1"
                       x:Name="DescText"
                       Text="NTFS 파일 시스템을 직접 읽어 빠르게 검색하는 도구입니다."
                       Foreground="#CCCCCC"
                       TextWrapping="Wrap"
                       Margin="0,8,0,16"/>
        </Grid>
    </Grid>
</Window>