<Window x:Class="HdrTracer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="HdrTracer"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        Closed="MainWindow_Closed"
        Closing="MainWindow_Closing"
        PreviewMouseWheel="Window_PreviewMouseWheel">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="L" Command="ApplicationCommands.Find"/>
        <KeyBinding Key="Escape" Command="NavigationCommands.BrowseStop"/>
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Find" Executed="FocusSearchCommand_Executed"/>
        <CommandBinding Command="NavigationCommands.BrowseStop" Executed="ClearAndFocusCommand_Executed"/>
    </Window.CommandBindings>

    <!-- 커스텀 타이틀바를 위해 WindowChrome 사용 -->
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="30"
            ResizeBorderThickness="6"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>  <!-- 타이틀바 -->
            <RowDefinition Height="*"/>   <!-- 본문 -->
        </Grid.RowDefinitions>

        <!-- ============ 타이틀바 ============ -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- 아이콘 -->
                <ColumnDefinition Width="Auto"/>  <!-- 앱 이름 -->
                <ColumnDefinition Width="*"/>     <!-- 드래그 영역 -->
                <ColumnDefinition Width="Auto"/>  <!-- 버튼들 -->
            </Grid.ColumnDefinitions>

            <!-- 아이콘 -->
            <Image Grid.Column="0"
                   Source="/Assets/sun.ico"
                   Width="20" Height="20"
                   Margin="10,0,8,0"
                   VerticalAlignment="Center"
                   WindowChrome.IsHitTestVisibleInChrome="True"/>

            <!-- 앱 이름 + ▼ 통합 버튼 (클릭 시 메뉴 팝업) -->
            <Button Grid.Column="1"
                    x:Name="MenuDropdownButton"
                    Click="MenuDropdownButton_Click"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    FocusVisualStyle="{StaticResource AppFocusVisual}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Padding="6,2"
                    VerticalAlignment="Center"
                    ToolTip="메뉴">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="3"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="HdrTracer"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="▼"
                               Foreground="#CCCCCC"
                               FontSize="9"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 가운데 영역은 드래그로 창 이동에 사용 (WindowChrome이 자동 처리) -->

            <!-- 윈도우 제어 버튼 (상단·오른쪽 6px는 리사이즈 테두리로 비워둠) -->
            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        Margin="0,6,6,0"
                        WindowChrome.IsHitTestVisibleInChrome="True">

                <!-- 최소화 -->
                <Button x:Name="MinimizeButton"
                        Click="MinimizeButton_Click"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Content="&#xE921;"
                        ToolTip="최소화"/>

                <!-- 최대화 / 복원 -->
                <Button x:Name="MaximizeButton"
                        Click="MaximizeButton_Click"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Content="&#xE922;"
                        ToolTip="최대화"/>

                <!-- 닫기 -->
                <Button x:Name="CloseButton"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"
                        Content="&#xE8BB;"
                        ToolTip="닫기"/>
            </StackPanel>
        </Grid>

        <!-- ============ 본문 영역 ============ -->
        <Grid Grid.Row="1" Margin="10,8,10,10">
            <Grid.LayoutTransform>
                <ScaleTransform x:Name="ContentScale" ScaleX="1.0" ScaleY="1.0"/>
            </Grid.LayoutTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 상태 표시 -->
                <RowDefinition Height="Auto"/>  <!-- 검색창 -->
                <RowDefinition Height="*"/>     <!-- 결과 리스트 -->
                <RowDefinition Height="Auto"/>  <!-- 하단 상태바 -->
            </Grid.RowDefinitions>

            <!-- 인덱싱 중일 때 표시 -->
            <Border x:Name="StatusBanner"
                    Grid.Row="0"
                    Background="#2D2D30"
                    Padding="10,6"
                    Margin="0,0,0,8"
                    CornerRadius="4">
                <TextBlock x:Name="StatusText"
                        Text="인덱스를 준비 중입니다..."
                        Foreground="#CCCCCC"
                        FontSize="12"/>
            </Border>

            <!-- 검색창 -->
            <Border Grid.Row="1"
                    Background="#2D2D30"
                    CornerRadius="4"
                    Padding="8,4"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchBox"
                            Grid.Column="0"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="14"
                            CaretBrush="White"
                            VerticalContentAlignment="Center"
                            TextChanged="SearchBox_TextChanged"
                            PreviewKeyDown="SearchBox_KeyDown"
                            PreviewMouseLeftButtonUp="SearchBox_Click"
                            IsEnabled="False">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="PlaceholderBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="검색어 입력..." Foreground="#666" FontSize="14"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource PlaceholderBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button x:Name="SearchButton"
                            Grid.Column="1"
                            Click="SearchButton_Click"
                            FocusVisualStyle="{StaticResource AppFocusVisual}"
                            Content="&#xE721;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="32"
                            Height="26"
                            ToolTip="검색">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 검색 히스토리 드롭다운 -->
            <Popup x:Name="HistoryPopup"
                   PlacementTarget="{Binding ElementName=SearchBox}"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False">
                <Border Background="#2D2D30"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,2,0,0">
                    <ListBox x:Name="HistoryList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             MaxHeight="320"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="HistoryList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding ActualWidth, ElementName=SearchBox}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding}"
                                               Foreground="#DDDDDD"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="10,7,6,7"/>
                                    <Button Grid.Column="1"
                                            Content="&#xE711;"
                                            Tag="{Binding}"
                                            Click="HistoryDelete_Click"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="10"
                                            Foreground="#888"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Width="28"
                                            ToolTip="{DynamicResource TipDelete}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>

            <!-- 결과 리스트 -->
            <Border Grid.Row="2"
                    Background="#252526"
                    CornerRadius="4">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                        x:Name="HeaderGrid"
                        Background="#333337"
                        Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Cols.Drive, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ColumnDefinition Width="{Binding Cols.Name, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <ColumnDefinition Width="*" MinWidth="60"/>
                            <ColumnDefinition Width="{Binding Cols.Size, RelativeSource={RelativeSource AncestorType=Window}}"/>    <!-- 크기 -->
                            <ColumnDefinition Width="{Binding Cols.Date, RelativeSource={RelativeSource AncestorType=Window}}"/>   <!-- 수정 날짜 -->
                            <ColumnDefinition Width="16"/>
                        </Grid.ColumnDefinitions>

                        <Grid.Resources>
                            <!-- 헤더 포커스: 컬럼 경계선 위치가 헤더마다 달라(안쪽 3.5px/바깥쪽),
                                 좌우 여백을 개별 보정해 모든 헤더에서 경계선과의 간격이
                                 동일(약 4.5px)하게 보이도록 한다. -->
                            <ControlTemplate x:Key="HeaderFocusDrv">
                                <Rectangle Margin="5,3,8,3" StrokeThickness="1.5" Stroke="#E8E8EC"
                                           StrokeDashArray="1 2" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                            <ControlTemplate x:Key="HeaderFocusName">
                                <Rectangle Margin="1,3,8,3" StrokeThickness="1.5" Stroke="#E8E8EC"
                                           StrokeDashArray="1 2" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                            <ControlTemplate x:Key="HeaderFocusPath">
                                <Rectangle Margin="1,3,1,3" StrokeThickness="1.5" Stroke="#E8E8EC"
                                           StrokeDashArray="1 2" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                            <ControlTemplate x:Key="HeaderFocusSize">
                                <Rectangle Margin="8,3,8,3" StrokeThickness="1.5" Stroke="#E8E8EC"
                                           StrokeDashArray="1 2" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                            <ControlTemplate x:Key="HeaderFocusDate">
                                <Rectangle Margin="1,3,-11.5,3" StrokeThickness="1.5" Stroke="#E8E8EC"
                                           StrokeDashArray="1 2" SnapsToDevicePixels="True"/>
                            </ControlTemplate>
                            <Style x:Key="FocusDrv">
                                <Setter Property="Control.Template" Value="{StaticResource HeaderFocusDrv}"/>
                            </Style>
                            <Style x:Key="FocusName">
                                <Setter Property="Control.Template" Value="{StaticResource HeaderFocusName}"/>
                            </Style>
                            <Style x:Key="FocusPath">
                                <Setter Property="Control.Template" Value="{StaticResource HeaderFocusPath}"/>
                            </Style>
                            <Style x:Key="FocusSize">
                                <Setter Property="Control.Template" Value="{StaticResource HeaderFocusSize}"/>
                            </Style>
                            <Style x:Key="FocusDate">
                                <Setter Property="Control.Template" Value="{StaticResource HeaderFocusDate}"/>
                            </Style>

                            <Style TargetType="Button" x:Key="HeaderButtonStyle">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Left"
                                                                VerticalAlignment="Center"
                                                                Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3F3F46"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#4A4A50"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!-- 컬럼 경계 드래그용 Thumb 스타일: 가는 세로 구분선 + 좌우조절 커서 -->
                            <Style TargetType="Thumb" x:Key="ColumnSplitterStyle">
                                <Setter Property="Width" Value="7"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Cursor" Value="SizeWE"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{TemplateBinding Background}">
                                                <!-- 가운데 1px 경계선 -->
                                                <Border Width="1" HorizontalAlignment="Center"
                                                        Background="#6E6E76"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!-- 왼쪽 가장자리에 붙는 경계 (경로|크기 경계용) -->
                            <Style TargetType="Thumb" x:Key="ColumnSplitterStyleLeft"
                                   BasedOn="{StaticResource ColumnSplitterStyle}">
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                            </Style>
                        </Grid.Resources>

                        <Button Grid.Column="0" x:Name="HdrDrive" Style="{StaticResource HeaderButtonStyle}" FocusVisualStyle="{StaticResource FocusDrv}"  Tag="Drive" Click="HeaderButton_Click" Content="DRV"/>
                        <Button Grid.Column="1" x:Name="HdrName" Style="{StaticResource HeaderButtonStyle}" FocusVisualStyle="{StaticResource FocusName}" Tag="Name"  Click="HeaderButton_Click" Content="이름"/>
                        <Button Grid.Column="2" x:Name="HdrPath" Style="{StaticResource HeaderButtonStyle}" FocusVisualStyle="{StaticResource FocusPath}" Tag="Path"  Click="HeaderButton_Click" Content="경로"/>
                        <Button Grid.Column="3" x:Name="HdrSize" Style="{StaticResource HeaderButtonStyle}" FocusVisualStyle="{StaticResource FocusSize}" Padding="15,0" Tag="Size"  Click="HeaderButton_Click" Content="크기"/>
                        <Button Grid.Column="4" x:Name="HdrDate" Style="{StaticResource HeaderButtonStyle}" FocusVisualStyle="{StaticResource FocusDate}" Tag="Date"  Click="HeaderButton_Click" Content="수정 날짜"/>

                        <!-- 컬럼 경계 드래그 핸들 -->
                        <Thumb Grid.Column="0" Style="{StaticResource ColumnSplitterStyle}"
                               Tag="ColDrive" DragDelta="ColumnSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted"/>
                        <Thumb Grid.Column="1" Style="{StaticResource ColumnSplitterStyle}"
                               Tag="ColName" DragDelta="ColumnSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted"/>
                        <!-- 경로|크기 경계: 크기 컬럼 왼쪽에 배치. 드래그하면 크기 컬럼 너비를 반대로 조절 -->
                        <Thumb Grid.Column="3" Style="{StaticResource ColumnSplitterStyleLeft}"
                               Tag="ColSizeLeft" DragDelta="ColumnSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted"/>
                        <!-- 크기|수정날짜 경계 -->
                        <Thumb Grid.Column="3" Style="{StaticResource ColumnSplitterStyle}"
                               Tag="ColSize" DragDelta="ColumnSplitter_DragDelta" DragCompleted="ColumnSplitter_DragCompleted"/>
                    </Grid>

                    <!-- 가상화 ListView (헤더 없는 순수 행) -->
                    <ListView x:Name="ResultsList"
                            Background="Transparent"
                            Foreground="#DDDDDD"
                            BorderThickness="0"
                            FontFamily="Consolas, Segoe UI"
                            FontSize="12"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.CanContentScroll="True"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling"
                            VirtualizingPanel.ScrollUnit="Item"
                            MouseDoubleClick="ResultsList_MouseDoubleClick"
                            PreviewMouseLeftButtonDown="ResultsList_PreviewMouseLeftButtonDown"
                            ContextMenuOpening="ResultsList_ContextMenuOpening"
                            PreviewKeyDown="ResultsList_KeyDown">
                        <ListView.InputBindings>
                            <KeyBinding Key="Enter" Command="ApplicationCommands.Open"/>
                            <KeyBinding Modifiers="Alt" Key="Enter" Command="ApplicationCommands.Properties"/>
                            <KeyBinding Modifiers="Control" Key="C" Command="ApplicationCommands.Copy"/>
                            <KeyBinding Modifiers="Control+Shift" Key="C" Command="NavigationCommands.GoToPage"/>
                        </ListView.InputBindings>

                        <ListView.CommandBindings>
                            <CommandBinding Command="ApplicationCommands.Open" Executed="OpenCommand_Executed"/>
                            <CommandBinding Command="ApplicationCommands.Properties" Executed="PropertiesCommand_Executed"/>
                            <CommandBinding Command="ApplicationCommands.Copy" Executed="CopyFileCommand_Executed"/>
                            <CommandBinding Command="NavigationCommands.GoToPage" Executed="CopyPathCommand_Executed"/>
                        </ListView.CommandBindings>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#DDDDDD"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="0"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2D2D30"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding Cols.Drive, ElementName=RootWindow}"/>
                                        <ColumnDefinition Width="{Binding Cols.Name, ElementName=RootWindow}"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="{Binding Cols.Size, ElementName=RootWindow}"/>
                                        <ColumnDefinition Width="{Binding Cols.Date, ElementName=RootWindow}"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Drive}"
                                            VerticalAlignment="Center" Margin="8,0,0,0"
                                            Foreground="#7CB7FF" FontWeight="SemiBold"/>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                        <Image Source="{Binding Icon}"
                                            Width="16" Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding Name}"
                                                VerticalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Path}"
                                            VerticalAlignment="Center" Margin="8,0,0,0"
                                            Foreground="#AAAAAA"
                                            TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding SizeText}"
                                            VerticalAlignment="Center" Margin="8,0,0,0"
                                            Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Column="4" Text="{Binding ModifiedText}"
                                            VerticalAlignment="Center" Margin="8,0,0,0"
                                            Foreground="#AAAAAA"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ContextMenu>
                            <ContextMenu Opened="ResultsContextMenu_Opened" Closed="ResultsContextMenu_Closed">
                                <MenuItem x:Name="CtxOpen" Header="열기" Click="MenuOpen_Click" InputGestureText="Enter"/>
                                <MenuItem x:Name="CtxRunAsAdmin" Header="관리자 권한으로 실행" Click="MenuRunAsAdmin_Click"/>
                                <MenuItem x:Name="CtxOpenWith" Header="다른 프로그램으로 열기" Click="MenuOpenWith_Click"/>
                                <Separator/>
                                <MenuItem x:Name="CtxReveal" Header="폴더에서 보기" Click="MenuRevealInExplorer_Click"/>
                                <Separator/>
                                <MenuItem x:Name="CtxCopyPath" Header="경로 복사" Click="MenuCopyPath_Click" InputGestureText="Ctrl+Shift+C"/>
                                <MenuItem x:Name="CtxCopyName" Header="이름 복사" Click="MenuCopyName_Click" InputGestureText="Ctrl+Shift+N"/>
                                <Separator/>
                                <MenuItem x:Name="CtxRename" Header="이름 바꾸기" Click="MenuRename_Click" InputGestureText="F2"/>
                                <MenuItem x:Name="CtxCopyFile" Header="파일 복사" Click="MenuCopyFile_Click" InputGestureText="Ctrl+C"/>
                                <MenuItem x:Name="CtxDelete" Header="휴지통으로 삭제" Click="MenuDelete_Click" InputGestureText="Del"/>
                                <Separator/>
                                <MenuItem x:Name="CtxProperties" Header="속성" Click="MenuProperties_Click" InputGestureText="Alt+Enter"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </DockPanel>
            </Border>

            <!-- 하단 상태바 -->
            <Border Grid.Row="3"
                    Background="#007ACC"
                    Margin="0,8,0,0"
                    Padding="10,4"
                    CornerRadius="4">
                <TextBlock x:Name="FooterText"
                        Text="준비 중"
                        Foreground="White"
                        FontSize="11"/>
