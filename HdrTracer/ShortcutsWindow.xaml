<Window x:Class="HdrTracer.App.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="TitleText"
                       Text="단축키"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
            <Button Grid.Column="1"
                    Click="CloseButton_Click"
                    Style="{StaticResource CloseButtonStyle}"
                    Content="&#xE8BB;"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- 본문 -->
        <StackPanel Grid.Row="1"
                    Margin="20,16,20,16">
            <StackPanel>
                <TextBlock x:Name="SecAppMenu" Text="앱 메뉴"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7CB7FF"
                           Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + ," Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RowOpenSettings" Text="설정 열기" Foreground="#CCCCCC" Margin="0,2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="F5" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RowRefresh" Text="인덱스 새로 고침" Foreground="#CCCCCC" Margin="0,2"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + +" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RowZoomIn" Text="확대" Foreground="#CCCCCC" Margin="0,2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + -" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RowZoomOut" Text="축소" Foreground="#CCCCCC" Margin="0,2"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl + 0" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RowZoomReset" Text="배율 초기화" Foreground="#CCCCCC" Margin="0,2"/>
                    </Grid>

                <TextBlock x:Name="SecSearchBox" Text="검색창"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7CB7FF"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + L" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RowFocusSearch" Text="검색창에 포커스" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RowClearSearch" Text="검색어 지우기" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="↓" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RowGotoResults" Text="결과 리스트로 이동" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + 1~9" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RowPinnedSearch" Text="고정 검색 실행 (📌 위에서부터 1~9)" Foreground="#CCCCCC" Margin="0,2"/>
                </Grid>

                <TextBlock x:Name="SecResultList" Text="결과 리스트"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7CB7FF"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Enter" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RowOpenItem1" Text="선택한 항목 열기" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Alt + Enter" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RowViewProps" Text="속성 보기" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + C" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RowCopyFile" Text="파일 복사" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + Shift + C" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RowCopyPath" Text="전체 경로 복사" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl + Shift + N" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RowCopyName" Text="파일 이름만 복사" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="RowUpFirst" Text="↑ (첫 행에서)" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="RowBackToSearch" Text="검색창으로 돌아가기" Foreground="#CCCCCC" Margin="0,2"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" x:Name="RowDblClick" Text="더블클릭" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="RowOpenItem2" Text="선택한 항목 열기" Foreground="#CCCCCC" Margin="0,2"/>
                </Grid>

                <TextBlock x:Name="SecGlobalSc" Text="전역 단축키"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7CB7FF"
                           Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Win + Alt + S" Foreground="#DDDDDD" FontFamily="Consolas" Margin="0,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RowToggleApp" Text="어디서든 앱 보이기/숨기기" Foreground="#CCCCCC" Margin="0,2"/>
                </Grid>

                <TextBlock x:Name="SecSearchTips" Text="검색 팁"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#7CB7FF"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="Tip1Text" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock x:Name="Tip2Text" Foreground="#888" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,4"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>