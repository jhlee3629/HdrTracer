<Window x:Class="HdrTracer.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="0"
            CornerRadius="0"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Tab 포커스 표시: 어두운 테마에서도 잘 보이는 밝은 사각형 -->
        <Style x:Key="BrightFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="-3"
                                   StrokeThickness="2"
                                   Stroke="#8A8A90"
                                   StrokeDashArray="2 1"
                                   RadiusX="3" RadiusY="3"
                                   SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <Grid Grid.Row="0" Background="#252526">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       x:Name="TitleText"
                       Text="설정"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"/>
            <Button Grid.Column="1"
                    x:Name="CloseButton"
                    Click="CloseButton_Click"
                    Style="{StaticResource CloseButtonStyle}"
                    FocusVisualStyle="{StaticResource BrightFocusVisual}"
                    Content="&#xE8BB;"
                    WindowChrome.IsHitTestVisibleInChrome="True"/>
        </Grid>

        <!-- 본문 -->
        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                    x:Name="SecIndexing"
                    Text="인덱싱"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#CCCCCC"
                    Margin="0,0,0,12"/>

            <!-- USB 토글 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="UsbTitle" Text="이동식 드라이브 인덱싱"
                            Foreground="White"
                            FontSize="13"/>
                    <TextBlock x:Name="UsbDesc" Text="USB 드라이브의 파일도 검색에 포함합니다."
                            Foreground="#888"
                            FontSize="11"
                            Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1"
                        x:Name="RemovableCheckBox"
                        VerticalAlignment="Center"
                        Style="{StaticResource DarkToggleStyle}"
                        FocusVisualStyle="{StaticResource BrightFocusVisual}"
                        Click="RemovableCheckBox_Click"/>
            </Grid>

            <!-- 트레이 토글 (새로 추가) -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TrayTitle" Text="닫기 버튼을 누르면 트레이로 숨김"
                            Foreground="White"
                            FontSize="13"/>
                    <TextBlock x:Name="TrayDesc" Text="X 버튼이 종료 대신 트레이로 보냅니다. 진짜 종료는 트레이 우클릭."
                            Foreground="#888"
                            FontSize="11"
                            Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox Grid.Column="1"
                        x:Name="TrayCheckBox"
                        VerticalAlignment="Center"
                        Style="{StaticResource DarkToggleStyle}"
                        FocusVisualStyle="{StaticResource BrightFocusVisual}"/>
            </Grid>

            <!-- 숨김+시스템 항목 표시 토글 -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="HiddenTitle" Text="숨김·시스템 항목 표시"
                            Foreground="White"
                            FontSize="13"/>
                    <TextBlock x:Name="HiddenDesc" Text="백신 보호 폴더 등 숨김+시스템 속성 항목도 검색 결과에 표시합니다."
                            Foreground="#888"
                            FontSize="11"
                            Margin="0,2,0,0"
                            TextWrapping="Wrap"/>
                </StackPanel>
                <CheckBox Grid.Column="1"
                        x:Name="HiddenSystemCheckBox"
                        VerticalAlignment="Center"
                        Style="{StaticResource DarkToggleStyle}"
                        FocusVisualStyle="{StaticResource BrightFocusVisual}"/>
            </Grid>

            <!-- Windows 시작 시 자동 실행 토글 -->
            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="AutoStartTitle" Text="Windows 시작 시 자동 실행"
                            Foreground="White"
                            FontSize="13"/>
                    <TextBlock x:Name="AutoStartDesc" Text="로그인하면 트레이에 자동으로 실행됩니다. (작업 스케줄러 등록, UAC 없음)"
                            Foreground="#888"
                            FontSize="11"
                            Margin="0,2,0,0"
                            TextWrapping="Wrap"/>
                </StackPanel>
                <CheckBox Grid.Column="1"
                        x:Name="AutoStartCheckBox"
                        VerticalAlignment="Center"
                        Style="{StaticResource DarkToggleStyle}"
                        FocusVisualStyle="{StaticResource BrightFocusVisual}"/>
            </Grid>

            <!-- 검색 제외 폴더 이름 -->
            <StackPanel Grid.Row="5" Margin="0,16,0,0">
                <TextBlock x:Name="ExcludedTitle" Text="검색에서 제외할 폴더 이름"
                        Foreground="White"
                        FontSize="13"/>
                <TextBlock x:Name="ExcludedDesc" Text="세미콜론(;)으로 구분. 이 이름의 폴더와 그 안의 모든 항목이 결과에서 숨겨집니다. 예: WinSxS; node_modules"
                        Foreground="#888"
                        FontSize="11"
                        Margin="0,2,0,6"
                        TextWrapping="Wrap"/>
                <TextBox x:Name="ExcludedBox"
                        Background="#1E1E1E"
                        Foreground="#F1F1F1"
                        BorderBrush="#3E3E42"
                        BorderThickness="1"
                        CaretBrush="#F1F1F1"
                        Padding="6,4"
                        FontSize="13"/>
            </StackPanel>

            <TextBlock Grid.Row="6"
                    x:Name="StatusText"
                    Foreground="#7CB7FF"
                    FontSize="11"
                    Margin="0,16,0,0"
                    TextWrapping="Wrap"/>
        </Grid>

        <!-- 하단 버튼 -->
        <Border Grid.Row="2" Background="#252526" Padding="20,8">
            <Grid>
                <Button x:Name="OkButton"
                        Click="OkButton_Click"
                        Content="확인"
                        HorizontalAlignment="Right"
                        Width="80"
                        Height="28"
                        Background="#0E639C"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FocusVisualStyle="{StaticResource BrightFocusVisual}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1177BB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>